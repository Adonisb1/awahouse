{
  "framework": "nextjs",
  "buildCommand": "pnpm db:generate && pnpm build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install",
  "nodeVersion": "20",
  "crons": [
    {
      "path": "/api/cron/process-jobs",
      "schedule": "0 6 * * *"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
