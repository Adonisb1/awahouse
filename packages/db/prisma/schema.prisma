generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

enum UserRole {
  tenant
  landlord
  agent
  admin
}

enum VerificationType {
  nin
  lasrera
  esvarbon
  niesv
  aean
  ercaan
  redan
  property_title
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum PropertyType {
  apartment
  duplex
  bungalow
  studio
  commercial
}

enum VerificationBadge {
  pending
  agent_verified
  title_confirmed
  fully_verified
}

enum ReviewType {
  property
  landlord
  agent
}

enum PaymentProvider {
  monnify
  paystack
}

enum EscrowStatus {
  pending_payment
  funds_held
  docs_verified
  key_handover_pending
  completed
  refunded
  cancelled
  disputed
}

enum RentInstalmentStatus {
  scheduled
  paid
  overdue
  missed
}

enum RentScoreEventType {
  on_time_payment
  late_payment
  missed_payment
  escrow_completed
  dispute_raised
}

model User {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone      String?
  email      String   @unique
  roles      UserRole[]
  activeRole UserRole @default(tenant) @map("active_role")
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  ninHash    String?  @unique @map("nin_hash")
  avatarUrl  String?  @map("avatar_url")
  rentScore  Int      @default(500) @map("rent_score")
  isDeleted  Boolean  @default(false) @map("is_deleted")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  verifications Verification[]
  properties    Property[]
  savedProperties SavedProperty[]
  reviewsWritten  Review[]       @relation("ReviewsWritten")
  reviewsReceived Review[]       @relation("ReviewsReceived")
  escrowTransactions EscrowTransaction[] @relation("TenantEscrows")
  escrowAsLandlord   EscrowTransaction[] @relation("LandlordEscrows")
  escrowAsAgent      EscrowTransaction[] @relation("AgentEscrows")
  notifications    Notification[]
  transactionLogs  TransactionLog[]
  rentInstalments  RentInstalment[]
  rentScoreEvents  RentScoreEvent[]

  landlordProfile LandlordProfile?

  @@map("users")
}

model LandlordProfile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  firmName    String?  @map("firm_name")
  bankName    String?  @map("bank_name")
  bankCode    String?  @map("bank_code")
  bankAccount String?  @map("bank_account")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("landlord_profiles")
}

model Property {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId           String           @map("owner_id") @db.Uuid
  title             String
  description       String?
  address           String?
  lga               String?
  type              PropertyType
  bedrooms          Int              @default(1)
  bathrooms         Int              @default(1)
  priceKobo         BigInt           @map("price_kobo")
  isAvailable       Boolean          @default(true) @map("is_available")
  isDeleted         Boolean          @default(false) @map("is_deleted")
  verificationBadge VerificationBadge @default(pending) @map("verification_badge")
  latitude          Float?
  longitude         Float?
  metadata          Json?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  owner    User             @relation(fields: [ownerId], references: [id])
  images   PropertyImage[]
  savedBy  SavedProperty[]
  reviews  Review[]
  escrows  EscrowTransaction[]

  @@index([lga])
  @@index([type])
  @@index([ownerId])
  @@index([priceKobo])
  @@index([createdAt])
  @@index([isAvailable, isDeleted, verificationBadge])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  url        String
  thumbnail  String?
  alt        String?
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model SavedProperty {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("saved_properties")
}

model Review {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewerId  String     @map("reviewer_id") @db.Uuid
  revieweeId  String     @map("reviewee_id") @db.Uuid
  propertyId  String?    @map("property_id") @db.Uuid
  escrowId    String?    @map("escrow_id") @db.Uuid
  type        ReviewType
  rating      Int
  comment     String?
  isVerified  Boolean    @default(false) @map("is_verified")
  isPublished Boolean    @default(true) @map("is_published")
  createdAt   DateTime   @default(now()) @map("created_at")

  reviewer User      @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  reviewee User      @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
  escrow   EscrowTransaction? @relation(fields: [escrowId], references: [id])

  @@unique([reviewerId, escrowId])
  @@index([propertyId])
  @@index([revieweeId])
  @@index([reviewerId])
  @@index([createdAt])
  @@map("reviews")
}

model Verification {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  type         VerificationType
  status       VerificationStatus @default(pending)
  metadata     Json?
  documentUrl  String?          @map("document_url")
  reviewerId   String?          @map("reviewer_id") @db.Uuid
  reviewedAt   DateTime?        @map("reviewed_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([status])
  @@map("verifications")
}

model EscrowTransaction {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  propertyId        String       @map("property_id") @db.Uuid
  tenantId          String       @map("tenant_id") @db.Uuid
  landlordId        String       @map("landlord_id") @db.Uuid
  agentId           String?      @map("agent_id") @db.Uuid
  status            EscrowStatus @default(pending_payment)
  amountKobo        BigInt       @map("amount_kobo")
  platformFeeKobo   BigInt       @map("platform_fee_kobo")
  landlordPayoutKobo BigInt      @map("landlord_payout_kobo")
  paymentProvider   PaymentProvider @default(monnify) @map("payment_provider")
  paymentReference  String?        @map("payment_reference")
  paymentAccessCode String?        @map("payment_access_code")
  disputeReason     String?        @map("dispute_reason")
  disputedAt        DateTime?      @map("disputed_at")
  completedAt       DateTime?      @map("completed_at")
  rentMonthly       Boolean        @default(false) @map("rent_monthly")
  payoutReference   String?        @map("payout_reference")
  payoutTransferCode String?       @map("payout_transfer_code")
  isDeleted         Boolean        @default(false) @map("is_deleted")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  tenant   User        @relation("TenantEscrows", fields: [tenantId], references: [id])
  landlord User        @relation("LandlordEscrows", fields: [landlordId], references: [id])
  agent    User?       @relation("AgentEscrows", fields: [agentId], references: [id])
  property Property    @relation(fields: [propertyId], references: [id])
  logs     TransactionLog[]
  reviews  Review[]
  instalments RentInstalment[]
  scoreEvents RentScoreEvent[]

  @@index([tenantId])
  @@index([landlordId])
  @@index([agentId])
  @@index([status])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([paymentReference])
  @@map("escrow_transactions")
}

model TransactionLog {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  escrowId   String       @map("escrow_id") @db.Uuid
  fromStatus EscrowStatus @map("from_status")
  toStatus   EscrowStatus @map("to_status")
  actorId    String       @map("actor_id") @db.Uuid
  reason     String?
  createdAt  DateTime     @default(now()) @map("created_at")

  escrow EscrowTransaction @relation(fields: [escrowId], references: [id])
  actor  User              @relation(fields: [actorId], references: [id])

  @@index([escrowId])
  @@map("transaction_logs")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  channel   String   @default("in_app")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model RentInstalment {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  escrowId          String               @map("escrow_id") @db.Uuid
  userId            String               @map("user_id") @db.Uuid
  instalmentNumber  Int                  @map("instalment_number")
  amountKobo        BigInt               @map("amount_kobo")
  dueDate           DateTime             @map("due_date")
  paidAt            DateTime?            @map("paid_at")
  status            RentInstalmentStatus @default(scheduled)
  retryCount        Int                  @default(0) @map("retry_count")
  paymentReference  String?              @map("payment_reference")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  user   User              @relation(fields: [userId], references: [id])
  escrow EscrowTransaction @relation(fields: [escrowId], references: [id])

  @@unique([escrowId, instalmentNumber])
  @@index([userId, status])
  @@index([dueDate])
  @@map("rent_instalments")
}

model RentScoreEvent {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  eventType RentScoreEventType @map("event_type")
  delta     Int
  scoreAfter Int              @map("score_after")
  escrowId  String?           @map("escrow_id") @db.Uuid
  metadata  Json?
  createdAt DateTime          @default(now()) @map("created_at")

  user   User              @relation(fields: [userId], references: [id])
  escrow EscrowTransaction? @relation(fields: [escrowId], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@map("rent_score_events")
}
